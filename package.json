{
  "name": "auto-clipper",
  "private": true,
  "version": "1.2.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "build": {
    "appId": "com.autoclipper.app",
    "productName": "Auto Clipper",
    "artifactName": "Auto Clipper Setup ${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "compression": "maximum",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "autoprefixer": "^10.5.2",
    "axios": "^1.6.0",
    "i18next": "^26.3.6",
    "lucide-react": "^1.24.0",
    "postcss": "^8.5.16",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.9",
    "react-router-dom": "^7.18.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.0.2",
    "vite": "^4.4.5"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-stronghold": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1"
  }
}
